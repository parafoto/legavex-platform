# ============================================================
# LegasVex — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Telegram Bot (Bot API mode) ──────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Telegram Userbot (Telethon / MTProto mode) ───────────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=+7XXXXXXXXXX

# ── Safety guards (do NOT change these defaults) ─────────────
HUMAN_APPROVAL_REQUIRED=true
DIRECT_CLIENT_DELIVERY=false

# ── RBAC — allowed Telegram user/chat IDs ───────────────────
# Comma-separated Telegram numeric IDs
LEGASVEX_TELEGRAM_ALLOWED_ACTOR_IDS=
LEGASVEX_TELEGRAM_ADMIN_ACTOR_IDS=
LEGASVEX_TELEGRAM_PRACTICE_LEAD_ACTOR_IDS=
LEGASVEX_TELEGRAM_ASSISTANT_ACTOR_IDS=
LEGASVEX_TELEGRAM_ALLOWED_CHAT_IDS=
LEGASVEX_TELEGRAM_RBAC_ENFORCED=true

# ── Local LLM (Ollama — privacy-first, recommended) ──────────
LEGASVEX_LOCAL_LLM_ENDPOINT=http://localhost:11434
LEGASVEX_LOCAL_LLM_MODEL=qwen2.5:7b
LEGASVEX_LLM_MODEL_DEFAULT=qwen2.5:7b
OLLAMA_HOST=127.0.0.1

# ── Cloud LLM (OpenRouter — optional fallback) ───────────────
LEGASVEX_ALLOW_CLOUD_LLM=false
OPENROUTER_API_KEY=
LEGASVEX_OPENROUTER_MODEL_DEFAULT=google/gemini-2.0-flash-001

# ── Agent Council ────────────────────────────────────────────
LEGASVEX_AGENT_COUNCIL_BUDGET=8
# Set to false to disable AI execution (rule-based fallback only)
LEGASVEX_AGENT_COUNCIL_EXECUTION_ENABLED=true
# Set to true for dry-run mode (no real LLM calls)
LEGASVEX_AGENT_COUNCIL_DRY_RUN=false

# ── Internal microservices ───────────────────────────────────
LEGASVEX_CRM_API_BASE=http://127.0.0.1:8010
LEGASVEX_INTAKE_API_BASE=http://127.0.0.1:8011
LEGASVEX_LEGAL_QA_API_BASE=http://127.0.0.1:8015
LEGASVEX_INTERNAL_API_TOKEN=

# ── Orchestrator ─────────────────────────────────────────────
# Options: memory | postgres
LEGASVEX_ORCHESTRATOR_BACKEND=memory

# ── Data & storage ───────────────────────────────────────────
LEGASVEX_LOCAL_DATA_DIR=./local_data
LEGASVEX_TENANT_SCOPE=demo-collegium
LEGASVEX_TELEGRAM_SESSION_DIR=./demo-data
LEGASVEX_TELEGRAM_SESSION_NAME=lawyer_telegram_assistant

# ── Document handling ────────────────────────────────────────
LEGASVEX_TELEGRAM_MAX_UPLOAD_MB=20
LEGASVEX_DOCUMENT_EXTRACT_MAX_CHARS=12000

# ── UI ───────────────────────────────────────────────────────
LEGASVEX_PREMIUM_UI=true

# ── Routing keywords (optional override) ─────────────────────
LEGASVEX_ROUTE_CONFIDENTIAL_KEYWORDS=
LEGASVEX_ROUTE_EXPERT_KEYWORDS=

# ── System ───────────────────────────────────────────────────
PYTHONIOENCODING=utf-8
LANG=ru_RU.UTF-8
