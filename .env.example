# ===========================================
# LegaVex Advisor Portal - Environment Config
# ===========================================
# Copy this file to .env and update values

# Database
POSTGRES_USER=legavex
POSTGRES_PASSWORD=legavex_secure_password
POSTGRES_DB=legavex_platform
DATABASE_URL=postgresql://legavex:legavex_secure_password@localhost:5432/legavex_platform

# JWT Authentication
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080  # 7 days

# SMTP / Email (Proton Mail or any SMTP)
SMTP_HOST=smtp.protonmail.ch
SMTP_PORT=587
SMTP_USER=legavex@proton.me
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM_NAME=LegaVex
EMAIL_ENABLED=false  # Set to true when ready to send real emails

# Business Logic
OFFER_TIMEOUT_HOURS=24

# API Settings
API_PREFIX=/api
DEBUG=true

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# NextAuth.js (for frontend)
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000
